# HF-AI Engine — Environment Variables
# Copy this file to .env and fill in the values you need.
# The engine runs with ZERO keys. All below are optional.

# MongoDB (default: localhost)
# MONGODB_URI=mongodb://localhost:27017

# ── RECOMMENDED: Macro data ──────────────────────────────────────────────────
# Free instant registration at https://fred.stlouisfed.org/docs/api/api_key.html
# Enables yield curve + Fed Funds Rate for macro module
# FRED_API_KEY=your_key_here

# ── OPTIONAL: Additional news headlines ──────────────────────────────────────
# newsapi.org free tier: 100 req/day
# NEWS_API_KEY=your_key_here

# ── OPTIONAL: Paid data upgrades (better India fundamentals) ─────────────────
# Financial Modeling Prep — fallback for India fundamentals
# FMP_API_KEY=your_key_here

# Alpha Vantage — fallback if yfinance unavailable
# ALPHA_VANTAGE_KEY=your_key_here

# ── OPTIONAL: LLM news sentiment (not recommended — FinBERT is free & better) ─
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
